# Option Analytics Platform — Environment Configuration
# Copy this file to .env and configure for your deployment

# Backend API URL (used by the Vite frontend dev server)
# For local development: http://localhost:8000
# For Docker: /api (NGINX proxy handles routing)
VITE_API_URL=http://localhost:8000

# NSE market data cache TTL in seconds (default: 300 = 5 minutes)
NSE_CACHE_TTL=300
